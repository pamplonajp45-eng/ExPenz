{
  "version": 2,
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(assets|static|_expo/static)/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/_expo/static/(.*)",
      "destination": "/_expo/static/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}